{
  "name": "anchorfact",
  "version": "0.2.0",
  "description": "Anchor AI to Facts — AI-structured knowledge base for LLM citations. Trust anchored in verifiable sources.",
  "type": "module",
  "scripts": {
    "build": "node src/compile.js content dist",
    "verify": "node src/verify-sources.js --incremental content verification-report.json",
    "verify-full": "node src/verify-sources.js content verification-report.json",
    "pipeline": "npm run verify && npm run build",
    "test": "node tests/confidence.test.js",
    "serve": "node src/serve.js",
    "deploy": "npm run pipeline && wrangler pages deploy dist",
    "monitor": "node scripts/monitor-sources.js --summary"
  },
  "keywords": [
    "geo",
    "knowledge-base",
    "llm",
    "ai-citations",
    "structured-data",
    "source-verification",
    "open-source"
  ],
  "license": "MIT",
  "author": "AnchorFact Contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/anchorfact/anchorfact.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
